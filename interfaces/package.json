{
  "dependencies": {
    "@genfeedai/constants": "2.2.2",
    "@genfeedai/enums": "2.2.2"
  },
  "devDependencies": {
    "@types/node": "25.3.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "mongoose": "9.2.4",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-icons": "5.6.0",
    "typescript": "5.9.3"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@genfeedai/interfaces",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "interfaces",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsc --build --force && if [ -d dist/src ]; then mv dist/src/* dist/ 2>/dev/null && rm -rf dist/src; fi",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "2.3.0"
}
